javascript:(function(){if(window._AC_PANEL){window._AC_PANEL.remove();if(window._AC_INT)clearInterval(window._AC_INT);window._AC_PANEL=null;return;}var clicks=0,locked=null,running=false,timer=null;var p=document.createElement('div');window._AC_PANEL=p;p.style.cssText='all:initial;position:fixed;top:20px;right:20px;z-index:2147483647;width:230px;background:#fff;border:1px solid #e0e0e0;border-radius:14px;padding:16px;font-family:-apple-system,sans-serif;font-size:13px;color:#111;box-shadow:0 4px 24px rgba(0,0,0,.12);';p.innerHTML='<div id="acHeader" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;cursor:grab"><div style="display:flex;align-items:center;gap:6px;font-weight:600;font-size:14px">&#9889; AutoClicker</div><div style="display:flex;align-items:center;gap:6px"><span id="acBadge" style="font-size:11px;padding:2px 9px;border-radius:20px;background:#f0f0f0;color:#888">idle</span><button id="acClose" style="background:none;border:none;font-size:16px;cursor:pointer;color:#aaa;line-height:1;padding:0">&times;</button></div></div><div style="background:#f7f7f7;border-radius:10px;padding:10px 12px;margin-bottom:10px"><div style="display:flex;justify-content:space-between;margin-bottom:5px"><span style="color:#888;font-size:12px">Interval</span><span id="acMs" style="font-weight:600">100 ms</span></div><input id="acSlider" type="range" min="10" max="2000" value="100" step="10" style="width:100%;margin:0"><div style="display:flex;justify-content:space-between;font-size:10px;color:#bbb;margin-top:2px"><span>fast</span><span>slow</span></div></div><div style="margin-bottom:10px"><div style="font-size:12px;color:#888;font-weight:500;margin-bottom:6px">Click target</div><div style="display:grid;grid-template-columns:1fr 1fr;gap:6px"><button id="acModeCursor" style="padding:6px;border-radius:8px;border:1.5px solid #111;background:#fff;font-size:12px;cursor:pointer;font-weight:500">Cursor pos</button><button id="acModeLock" style="padding:6px;border-radius:8px;border:1px solid #e0e0e0;background:#f7f7f7;font-size:12px;cursor:pointer;color:#888">Lock element</button></div><div id="acHint" style="display:none;font-size:11px;color:#999;margin-top:5px;padding:5px 8px;background:#f7f7f7;border-radius:8px">Right-click any element to lock it</div><div id="acLockName" style="display:none;font-size:11px;color:#4caf50;margin-top:5px;padding:5px 8px;background:#f0faf0;border-radius:8px"></div></div><div style="margin-bottom:12px"><div style="font-size:12px;color:#888;font-weight:500;margin-bottom:6px">Limit clicks</div><div style="display:flex;align-items:center;gap:8px"><input id="acLimitOn" type="checkbox"><input id="acLimitN" type="number" min="1" value="100" disabled style="width:68px;font-size:12px;padding:4px 8px;border-radius:8px;border:1px solid #e0e0e0;background:#f7f7f7"><span style="font-size:12px;color:#aaa">max clicks</span></div></div><div style="border-top:1px solid #f0f0f0;padding-top:10px;margin-bottom:12px;display:flex;justify-content:space-between"><span style="color:#888;font-size:12px">Total clicks</span><span id="acCount" style="font-weight:700;font-size:15px">0</span></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:7px"><button id="acStart" style="padding:9px;border-radius:9px;border:1px solid #e0e0e0;background:#fff;font-size:13px;font-weight:600;cursor:pointer">Start</button><button id="acReset" style="padding:9px;border-radius:9px;border:1px solid #e0e0e0;background:#f7f7f7;font-size:13px;cursor:pointer;color:#888">Reset</button></div>';document.body.appendChild(p);var mode='cursor';function setMode(m){mode=m;document.getElementById('acModeCursor').style.cssText=m==='cursor'?'padding:6px;border-radius:8px;border:1.5px solid #111;background:#fff;font-size:12px;cursor:pointer;font-weight:500':'padding:6px;border-radius:8px;border:1px solid #e0e0e0;background:#f7f7f7;font-size:12px;cursor:pointer;color:#888';document.getElementById('acModeLock').style.cssText=m==='lock'?'padding:6px;border-radius:8px;border:1.5px solid #111;background:#fff;font-size:12px;cursor:pointer;font-weight:500':'padding:6px;border-radius:8px;border:1px solid #e0e0e0;background:#f7f7f7;font-size:12px;cursor:pointer;color:#888';document.getElementById('acHint').style.display=m==='lock'?'block':'none';if(m==='cursor'){locked=null;document.getElementById('acLockName').style.display='none';}}document.getElementById('acModeCursor').onclick=function(){setMode('cursor');};document.getElementById('acModeLock').onclick=function(){setMode('lock');};document.getElementById('acSlider').oninput=function(){document.getElementById('acMs').textContent=this.value+' ms';};document.getElementById('acLimitOn').onchange=function(){document.getElementById('acLimitN').disabled=!this.checked;};function doClick(){var el=locked||(function(){var x=window.innerWidth/2,y=window.innerHeight/2;var t=document.elementFromPoint(x,y);return t&&!p.contains(t)?t:document.body;})();el.dispatchEvent(new MouseEvent('click',{bubbles:true,cancelable:true,view:window}));clicks++;document.getElementById('acCount').textContent=clicks;var lim=document.getElementById('acLimitOn').checked?parseInt(document.getElementById('acLimitN').value):null;if(lim&&clicks>=lim)stop();}function start(){if(running)return;running=true;var ms=parseInt(document.getElementById('acSlider').value);timer=setInterval(doClick,ms);var s=document.getElementById('acStart');s.textContent='Stop';s.style.background='#fff0f0';s.style.color='#d32f2f';s.style.border='1px solid #f5c6c6';document.getElementById('acBadge').textContent='active';document.getElementById('acBadge').style.background='#e8f5e9';document.getElementById('acBadge').style.color='#388e3c';}function stop(){if(!running)return;running=false;clearInterval(timer);timer=null;var s=document.getElementById('acStart');s.textContent='Start';s.style.background='#fff';s.style.color='#111';s.style.border='1px solid #e0e0e0';document.getElementById('acBadge').textContent='idle';document.getElementById('acBadge').style.background='#f0f0f0';document.getElementById('acBadge').style.color='#888';}document.getElementById('acStart').onclick=function(){running?stop():start();};document.getElementById('acReset').onclick=function(){stop();clicks=0;document.getElementById('acCount').textContent='0';locked=null;document.getElementById('acLockName').style.display='none';};document.getElementById('acClose').onclick=function(){stop();p.remove();window._AC_PANEL=null;};document.addEventListener('contextmenu',function(e){if(p.contains(e.target))return;if(mode!=='lock')return;e.preventDefault();locked=e.target;var name=e.target.id?'#'+e.target.id:e.target.tagName.toLowerCase()+(e.target.className?' .'+e.target.className.split(' ')[0]:'');var n=document.getElementById('acLockName');n.textContent='Locked: '+name;n.style.display='block';},true);var hdr=document.getElementById('acHeader');var dx=0,dy=0,dragging=false;hdr.addEventListener('mousedown',function(e){if(e.target===document.getElementById('acClose'))return;dragging=true;dx=e.clientX-p.getBoundingClientRect().left;dy=e.clientY-p.getBoundingClientRect().top;hdr.style.cursor='grabbing';e.preventDefault();});document.addEventListener('mousemove',function(e){if(!dragging)return;p.style.left=(e.clientX-dx)+'px';p.style.top=(e.clientY-dy)+'px';p.style.right='auto';});document.addEventListener('mouseup',function(){if(!dragging)return;dragging=false;hdr.style.cursor='grab';});})();
